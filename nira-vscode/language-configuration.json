{
  "$schema": "vscode://schemas/language-configuration",
  "comments": {
    "lineComment": {
      "comment": "#"
    }
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(if|else|for|while|arena|main|[^:]+:)\\s*$",
    "decreaseIndentPattern": "^\\s*(else)\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(if|else|for|while|arena|main|[^:]+:)\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}
